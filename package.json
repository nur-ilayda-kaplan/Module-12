{
  "name": "ui-test-framework",
  "version": "1.0.0",
  "description": "UI automation project with Playwright and Cucumber",
  "scripts": {
    "test": "playwright test",
    "test:ui": "cucumber-js --require-module ts-node/register --require step-definitions/**/*.ts --publish-quiet",
    "test:ui:tag": "npm run test:ui -- --tags",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@cucumber/cucumber": "^8.0.0",
    "express": "^4.18.0",
    "playwright": "^1.35.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.0",
    "@types/node": "^18.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^4.9.5",
    "eslint": "^8.46.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "prettier": "^3.0.0",
    "eslint-config-prettier": "^9.0.0"
  }
}
